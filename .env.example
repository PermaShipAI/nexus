# =============================================================================
# Agent System — Environment Configuration
# =============================================================================
# Most users don't need this file! Running `npm run dev:ui` will prompt you
# interactively for the LLM provider and API key, and the embedded database
# requires no configuration.
#
# Copy this to .env only if you want to override defaults.

# ── LLM Provider ────────────────────────────────────────────────────────────
# Set via interactive prompt on first run, or manually here.
# LLM_PROVIDER=gemini            # gemini, anthropic, openai, ollama, openrouter
# LLM_API_KEY=                   # API key for your provider
# GEMINI_API_KEY=                # Alternative: Gemini-specific key

# ── Database ────────────────────────────────────────────────────────────────
# Default: embedded PGlite (zero-config, stored in ./data/pglite/)
# Set DATABASE_URL to use external PostgreSQL instead:
# DATABASE_URL=postgresql://agents:agents@localhost:5432/agents

# ── Execution Backend ───────────────────────────────────────────────────────
# What runs approved tickets. Default: noop (track only)
# EXECUTION_BACKEND=claude-code  # claude-code, gemini-cli, codex-cli, openclaw, permaship

# ── Optional ────────────────────────────────────────────────────────────────
# LOCAL_UI_PORT=3000
# LOG_LEVEL=info
# ADAPTER_PROFILE=default        # default or permaship
